---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  client: string;
  year: string;
  tagline: string;
  role: string;
  metrics: { value: string; label: string }[];
  stack: string[];
}

const { title, client, year, tagline, role, metrics, stack } = Astro.props;
---

<Layout
  title={`${title} — Bautista Fernandez`}
  description={`${tagline} A case study on modernizing legacy systems for a ${client.toLowerCase()}.`}
>
  <Nav />
  <main class="pt-30 pb-16">
    <div class="container mx-auto px-6 max-w-4xl">
      <a href="/#projects" class="inline-flex items-center gap-2 font-mono text-sm text-teal-retro hover:text-mint transition-colors mb-8">
        <span>◂</span>
        <span>back to projects</span>
      </a>

      <header class="mb-12 pb-12 border-b-2 border-indigo/40">
        <div class="flex flex-wrap items-center gap-3 mb-4 font-mono text-xs text-teal-retro uppercase tracking-wider">
          <span>{client}</span>
          <span class="text-mint/40">◆</span>
          <span>{year}</span>
          <span class="text-mint/40">◆</span>
          <span>{role}</span>
        </div>

        <h1 class="font-pixelbig text-5xl md:text-6xl text-mint mb-4">
          {title}
        </h1>

        <p class="font-typewriter text-2xl text-teal-retro">
          {tagline}
        </p>
      </header>

      <div class="grid grid-cols-3 gap-4 mb-12 p-6 border-2 border-mint bg-indigo/10">
        {metrics.map((metric) => (
          <div class="text-center">
            <p class="font-pixelbig text-3xl md:text-4xl text-mint mb-2">{metric.value}</p>
            <p class="font-mono text-xs text-mint/60 uppercase tracking-wider">{metric.label}</p>
          </div>
        ))}
      </div>

      <article class="prose-custom font-mono text-mint/85 leading-relaxed space-y-6">
        <slot />
      </article>

      <div class="mt-12 pt-8 border-t-2 border-indigo/40">
        <p class="font-mono text-xs text-teal-retro mb-3">// full stack</p>
        <div class="flex flex-wrap gap-2">
          {stack.map((tech) => (
            <span class="px-3 py-1 border border-indigo bg-indigo/20 text-mint/90 text-sm font-mono">
              {tech}
            </span>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 border-2 border-dashed border-mint/40 text-center">
        <p class="font-typewriter text-2xl text-teal-retro mb-3">
          Have a legacy system to modernize?
        </p>
        <p class="font-mono text-sm text-mint/70 mb-6 max-w-xl mx-auto">
          If any of this sounds familiar to what you're going through, let's talk.
        </p>
        <a href="/#contact" class="inline-block px-6 py-3 bg-mint text-plum font-mono font-bold border-2 border-mint hover:bg-transparent hover:text-mint transition-all">
          Get in touch ▸
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .prose-custom h2 {
    font-family: 'VT323', monospace;
    font-size: 2.5rem;
    color: #8cefb6;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose-custom h3 {
    font-family: 'Special Elite', serif;
    font-size: 1.5rem;
    color: #6dbcb9;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom p {
    margin-bottom: 1.25rem;
  }
  .prose-custom ul {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }
  .prose-custom ul li {
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .prose-custom ul li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: #6dbcb9;
  }
  .prose-custom strong {
    color: #8cefb6;
    font-weight: 700;
  }
  .prose-custom code {
    background: rgba(71, 68, 118, 0.3);
    padding: 0.1rem 0.4rem;
    border: 1px solid rgba(71, 68, 118, 0.6);
    font-size: 0.9em;
    color: #8cefb6;
  }
  .prose-custom blockquote {
    border-left: 3px solid #6dbcb9;
    padding-left: 1.5rem;
    font-family: 'Special Elite', serif;
    color: #6dbcb9;
    margin: 2rem 0;
  }
</style>