---
const projects = [
  {
    id: '01',
    slug: 'customs-integration-platform',
    year: '2025',
    title: 'Customs Integration Platform',
    client: 'Customs Brokerage Firm',
    tagline: 'Replaced a 20-process legacy system with a single, modern service.',
    description: 'A customs brokerage firm was running 20 parallel legacy processes to sync with the national customs authority. Slow, memory-heavy, and impossible to monitor. I designed and built a unified .NET service that replaced all of it, with automatic failure detection and recovery.',
    metrics: [
      { value: '2h → 10s', label: 'per sync cycle' },
      { value: '16 GB → 300 MB', label: 'RAM (from GBs)' },
      { value: '24/7', label: 'in production' },
    ],
    stack: ['.NET 10', 'C#', 'Worker Service', 'MySQL', 'SOAP', 'WhatsApp API'],
    status: 'shipped',
  },
  {
    id: '02',
    slug: 'customs-notification-system',
    year: '2025',
    title: 'Automated Notification System',
    client: 'Customs Brokerage Firm',
    tagline: 'Modernizing critical operations without touching the legacy system.',
    description: 'A daily task that consumed hours of manual work: notifying every client when their shipment was released. I built a modern web app that reads directly from the legacy database (read-only) and automates the whole process, without changing a single line of the original system.',
    metrics: [
      { value: '10 minutes → 25 seconds', label: 'per notification' },
      { value: 'Zero errors', label: 'in critical data' },
      { value: 'Multi-tenant', label: 'ready' },
    ],
    stack: ['Blazor WASM', '.NET 10', 'PostgreSQL', 'MySQL', 'Nginx', 'Linux VPS'],
    status: 'shipped',
  },
  {
    id: '03',
    slug: 'legacy-php-modernization',
    year: '2024',
    title: 'Legacy PHP App Modernization',
    client: 'Growin Consulting | Public-Tender Platform',
    tagline: 'Feature delivery and performance work on a 10-year-old codebase.',
    description: 'Ongoing work on a legacy PHP platform with no documentation and a proprietary in-house framework. I reverse-engineered a broken production scraper, built a tiered access system for new AI features, and audited the codebase for performance bottlenecks. Zero downtime, incremental delivery.',
    metrics: [
      { value: '100% → 0%', label: 'scraper failure rate' },
      { value: '3 tiers', label: 'access system' },
      { value: 'Zero downtime', label: 'deployments' },
    ],
    stack: ['PHP 7.4', 'MySQL', 'Smarty', 'Legacy Framework', 'Stripe'],
    status: 'shipped',
  },
];
---

<section id="projects" class="py-24">
  <div class="container mx-auto px-6">
    <div class="mb-12">
      <p class="font-mono text-sm text-teal-retro mb-2">// 03</p>
      <h2 class="font-pixelbig text-5xl md:text-6xl text-mint mb-4">Selected work</h2>
      <p class="font-mono text-mint/70 max-w-2xl">
        Real projects, real clients. Names are anonymized to respect confidentiality — the technical details and impact are not.
      </p>
    </div>

    <div class="space-y-8">
      {projects.map((project) => (
        <article class="group border-2 border-indigo bg-plum hover:border-mint transition-all duration-300">
          <div class="grid md:grid-cols-[auto_1fr] gap-0">
            <div class="border-b-2 md:border-b-0 md:border-r-2 border-indigo group-hover:border-mint p-6 md:w-32 flex md:flex-col items-center md:items-start justify-between md:justify-start gap-4 bg-indigo/10 transition-colors">
              <div>
                <p class="font-pixel text-xs text-teal-retro mb-2">#{project.id}</p>
                <p class="font-pixelbig text-2xl text-mint">{project.year}</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-block w-2 h-2 bg-mint rounded-full animate-pulse"></span>
                <span class="font-mono text-xs text-mint uppercase tracking-wider">
                  {project.status}
                </span>
              </div>
            </div>

            <div class="p-8">
              <div class="mb-4">
                <p class="font-mono text-xs text-teal-retro uppercase tracking-wider mb-2">
                  {project.client}
                </p>
                <h3 class="font-pixelbig text-3xl md:text-4xl text-mint mb-2">
                  {project.title}
                </h3>
                <p class="font-typewriter text-lg text-teal-retro">
                  {project.tagline}
                </p>
              </div>

              <p class="font-mono text-sm text-mint/80 mb-6 leading-relaxed">
                {project.description}
              </p>

              <div class="grid grid-cols-3 gap-4 mb-6 py-4 border-y border-indigo/40">
                {project.metrics.map((metric) => (
                  <div>
                    <p class="font-pixelbig text-2xl text-mint mb-1">{metric.value}</p>
                    <p class="font-mono text-xs text-mint/60 uppercase tracking-wider">{metric.label}</p>
                  </div>
                ))}
              </div>

              <div class="mb-6">
                <p class="font-mono text-xs text-teal-retro mb-2">// stack</p>
                <div class="flex flex-wrap gap-2">
                  {project.stack.map((tech) => (
                    <span class="px-2 py-1 border border-indigo bg-indigo/20 text-mint/90 text-xs font-mono">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              <a
                href={`/projects/${project.slug}`}
                class="inline-flex items-center gap-3 px-6 py-3 border-2 border-mint text-mint font-mono hover:bg-mint hover:text-plum transition-all"
              >
                <span>Read case study</span>
                <span class="group-hover:translate-x-1 transition-transform">▸</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="font-typewriter text-xl text-teal-retro mb-4">
        More projects available on request
      </p>
      
      <a
        href="https://github.com/BautistaFernandez"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-6 py-3 border-2 border-mint text-mint font-mono hover:bg-mint hover:text-plum transition-all"
      >
        Check my GitHub ↗
      </a>
    </div>
  </div>
</section>