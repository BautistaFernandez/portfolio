---
const stats = [
  { label: 'Focus', value: '.NET / Legacy' },
  { label: 'Location', value: 'Remote / Argentina' },
  { label: 'Status', value: 'Freelance' },
  { label: 'Also', value: 'Game Dev' },
];

const techStack = [
  '.NET', 'C#', 'ASP.NET', 'SQL Server', 'MySQL', 'PostgreSQL',
   'PHP', 'REST APIs', 'Git', 'Unity', 'Docker'
];
---

<section id="about" class="py-24 relative">
  <div class="container mx-auto px-6">
    <div class="mb-12">
      <p class="font-mono text-sm text-teal-retro mb-2">// 01</p>
      <h2 class="font-pixelbig text-5xl md:text-6xl text-mint">About me</h2>
    </div>

    <div class="grid md:grid-cols-[2fr_1fr] gap-12">
      <div class="space-y-6 font-mono text-mint/80 leading-relaxed">
        <p>
          I'm a developer who enjoys the parts of software most people
          avoid: understanding old systems, figuring out why they were
          built that way, and bringing them into the present without
          breaking what already works.
        </p>

        <p>
          My day-to-day is modernizing legacy applications, migrating
          codebases to .NET, and building the integrations that keep
          businesses running. I care about writing code that other
          developers can read six months from now, and about shipping
          things that actually solve the problem.
        </p>

        <p>
          On the side, I study game development. It's where I got started
          and it's still what I love most about programming, the feeling
          that you're building something people will actually experience.
        </p>

        <div class="pt-4">
          <p class="font-mono text-sm text-teal-retro mb-3">// tech I work with</p>
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="px-3 py-1 border border-indigo bg-plum text-mint text-sm font-mono hover:border-mint hover:bg-indigo/30 transition-all">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>

      <aside class="relative">
        <div class="border-2 border-mint bg-indigo/20 p-6 relative">
          <div class="absolute -top-3 left-4 bg-plum px-2">
            <p class="font-pixel text-mint text-xs">CHARACTER</p>
          </div>

          <div class="space-y-4 mt-2">
            {stats.map((stat) => (
              <div>
                <p class="font-mono text-xs text-teal-retro uppercase tracking-wider mb-1">
                  {stat.label}
                </p>
                <p class="font-pixelbig text-2xl text-mint">
                  {stat.value}
                </p>
              </div>
            ))}
          </div>

          <div class="mt-6 pt-4 border-t border-indigo/60">
            <p class="font-mono text-xs text-mint/60 mb-2">// LVL</p>
            <div class="flex items-center gap-2">
              <div class="flex-1 h-3 bg-plum border border-indigo overflow-hidden">
                <div class="h-full bg-mint w-4/5 relative">
                  <div class="absolute inset-0 bg-linear-to-r from-transparent to-teal-retro/50"></div>
                </div>
              </div>
              <span class="font-pixel text-xs text-mint">80</span>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-2 -right-2 w-full h-full border-2 border-mint/30 -z-10"></div>
      </aside>
    </div>
  </div>
</section>