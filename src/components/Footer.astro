---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-indigo/40 py-8">
  <div class="container mx-auto px-6">
    <div class="flex flex-col sm:flex-row flex-wrap items-center justify-between gap-4 text-center sm:text-left">
      <p class="font-mono text-xs text-mint/50">
        © {currentYear} Bautista Fernandez — Built with <span class="text-teal-retro">Astro</span>
      </p>
      <p class="font-pixel text-[10px] text-mint/40">
        {'<GAME OVER? PRESS START/>'}
      </p>
      <a href="#hero" class="font-mono text-xs text-teal-retro hover:text-mint transition-colors">
        ▲ back to top
      </a>
    </div>
  </div>
</footer>